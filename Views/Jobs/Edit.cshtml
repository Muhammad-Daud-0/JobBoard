@model JobBoard.Models.DTOs.Jobs.UpdateJobDto
@using JobBoard.Models.Entities
@{
    ViewData["Title"] = "Edit Job";
    int jobId = ViewBag.JobId;
}

<div class="page-header">
    <div>
        <h1>Edit Job Listing</h1>
        <p class="page-subtitle">Update your job posting details</p>
    </div>
    <a asp-controller="Jobs" asp-action="Details" asp-route-id="@jobId" class="btn btn-ghost btn-sm">← Back to Listing</a>
</div>

<div style="max-width:700px;">
    <div class="card">
        <form asp-action="Edit" asp-route-id="@jobId" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="validation-summary-errors" style="display:@(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>

            <div class="form-group">
                <label class="form-label" asp-for="Title">Job Title *</label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="field-validation-error"></span>
            </div>

            <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem;">
                <div class="form-group">
                    <label class="form-label" asp-for="Location">Location *</label>
                    <input asp-for="Location" class="form-control" />
                    <span asp-validation-for="Location" class="field-validation-error"></span>
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="SalaryRange">Salary Range *</label>
                    <input asp-for="SalaryRange" class="form-control" />
                </div>
            </div>

            <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:1rem;">
                <div class="form-group">
                    <label class="form-label" asp-for="Type">Job Type</label>
                    <select asp-for="Type" class="form-control"
                            asp-items="Html.GetEnumSelectList<JobType>()"></select>
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="Status">Status</label>
                    <select asp-for="Status" class="form-control"
                            asp-items="Html.GetEnumSelectList<JobStatus>()"></select>
                </div>
                <div class="form-group">
                    <label class="form-label" asp-for="CategoryId">Category</label>
                    <select asp-for="CategoryId" class="form-control"
                            asp-items="ViewBag.Categories as Microsoft.AspNetCore.Mvc.Rendering.SelectList">
                        <option value="0">-- Select --</option>
                    </select>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label" asp-for="Description">Description *</label>
                <textarea asp-for="Description" class="form-control" rows="10"></textarea>
                <span asp-validation-for="Description" class="field-validation-error"></span>
            </div>

            <div style="display:flex; gap:0.75rem; justify-content:flex-end;">
                <a asp-action="Details" asp-route-id="@jobId" class="btn btn-ghost">Cancel</a>
                <button type="submit" class="btn btn-primary">💾 Save Changes</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScripts" />
}
