@model IEnumerable<JobBoard.Models.DTOs.Applications.ApplicationListDto>
@using JobBoard.Models.Entities
@{
    ViewData["Title"] = "My Applications";
}

<div class="page-header reveal">
    <div>
        <h1>My Applications</h1>
        <p class="page-subtitle">Track every application and its current status</p>
    </div>
    <a asp-controller="Jobs" asp-action="Index" class="btn btn-primary btn-sm">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        Browse Jobs
    </a>
</div>

@if (!Model.Any())
{
    <div class="empty-state reveal">
        <span class="empty-icon">📄</span>
        <h3>No applications yet</h3>
        <p>Start applying to jobs that match your skills and interests</p>
        <a asp-controller="Jobs" asp-action="Index" class="btn btn-primary" style="margin-top:1.5rem;">Browse Open Positions</a>
    </div>
}
else
{
    <!-- Stats Row -->
    <div class="stats-grid reveal" style="margin-bottom:2.5rem;">
        <div class="stat-card">
            <span class="stat-value">@Model.Count()</span>
            <span class="stat-label">Total Applied</span>
        </div>
        <div class="stat-card">
            <span class="stat-value" style="-webkit-text-fill-color:var(--yellow);">@Model.Count(a => a.Status == ApplicationStatus.Pending)</span>
            <span class="stat-label">Pending Review</span>
        </div>
        <div class="stat-card">
            <span class="stat-value" style="-webkit-text-fill-color:var(--blue);">@Model.Count(a => a.Status == ApplicationStatus.Shortlisted)</span>
            <span class="stat-label">Shortlisted 🎉</span>
        </div>
        <div class="stat-card">
            <span class="stat-value" style="-webkit-text-fill-color:var(--red);">@Model.Count(a => a.Status == ApplicationStatus.Rejected)</span>
            <span class="stat-label">Rejected</span>
        </div>
    </div>

    <!-- Application Cards -->
    <div style="display:flex;flex-direction:column;gap:1rem;">
        @{int i = 0;}
        @foreach (var app in Model)
        {
            i++;
            <div class="card card-hover reveal" style="animation-delay:@(i * 0.07)s; padding:1.5rem;">
                <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;flex-wrap:wrap;">
                    <div style="display:flex;align-items:flex-start;gap:1rem;">
                        <div style="width:44px;height:44px;border-radius:var(--radius-md);
                                    background:linear-gradient(135deg,rgba(99,102,241,0.2),rgba(139,92,246,0.15));
                                    border:1px solid var(--border-accent);
                                    display:flex;align-items:center;justify-content:center;font-size:1.2rem;flex-shrink:0;">
                            🏢
                        </div>
                        <div>
                            <div style="font-weight:700;font-size:1rem;margin-bottom:2px;">@app.JobTitle</div>
                            <div style="color:var(--accent-light);font-size:0.85rem;font-weight:600;">@app.CompanyName</div>
                            <div style="color:var(--text-muted);font-size:0.78rem;margin-top:3px;">📍 @app.Location</div>
                        </div>
                    </div>
                    <div style="display:flex;flex-direction:column;align-items:flex-end;gap:6px;">
                        <span class="badge @GetStatusBadge(app.Status)" style="font-size:0.78rem;padding:0.3rem 0.75rem;">
                            @GetStatusIcon(app.Status) @app.Status
                        </span>
                        <span style="font-size:0.75rem;color:var(--text-muted);">@app.AppliedAt.ToString("MMM dd, yyyy")</span>
                    </div>
                </div>

                <div style="margin-top:1rem;padding-top:1rem;border-top:1px solid var(--border);
                            display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap;">
                    <div style="flex:1; min-width:250px;">
                        <p style="font-size:0.82rem;color:var(--text-muted);margin-bottom:0.4rem;
                                   display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                            <strong style="color:var(--text-secondary);">Cover:</strong> @app.CoverLetter
                        </p>
                        @if (!string.IsNullOrEmpty(app.CvPath))
                        {
                            <a href="@app.CvPath" target="_blank" style="font-size:0.8rem;color:var(--accent-light);text-decoration:none;display:inline-flex;align-items:center;gap:4px;">
                                📄 My CV (@(app.CvFileName ?? "View"))
                            </a>
                        }
                    </div>
                    <div style="display:flex;align-items:center;gap:0.5rem;flex-shrink:0;">
                        <a asp-controller="Chat" asp-action="Index" asp-route-withUserId="@app.EmployerId" class="btn btn-ghost btn-sm">💬 Chat</a>
                        <a asp-controller="Jobs" asp-action="Details" asp-route-id="@app.JobId" class="btn btn-ghost btn-sm">View Job →</a>
                    </div>
                </div>
            </div>
        }
    </div>
}

@functions {
    string GetStatusBadge(JobBoard.Models.Entities.ApplicationStatus s) => s switch {
        JobBoard.Models.Entities.ApplicationStatus.Pending    => "badge-yellow",
        JobBoard.Models.Entities.ApplicationStatus.Reviewed   => "badge-blue",
        JobBoard.Models.Entities.ApplicationStatus.Shortlisted=> "badge-green",
        JobBoard.Models.Entities.ApplicationStatus.Rejected   => "badge-red",
        _ => "badge-gray"
    };
    string GetStatusIcon(JobBoard.Models.Entities.ApplicationStatus s) => s switch {
        JobBoard.Models.Entities.ApplicationStatus.Pending    => "⏳",
        JobBoard.Models.Entities.ApplicationStatus.Reviewed   => "👀",
        JobBoard.Models.Entities.ApplicationStatus.Shortlisted=> "⭐",
        JobBoard.Models.Entities.ApplicationStatus.Rejected   => "✕",
        _ => "•"
    };
}
