@{
    ViewData["Title"] = "About Us";
}

<div class="hero reveal">
    <div class="hero-bg"></div>
    <div class="hero-grid-lines"></div>
    
    <div class="hero-content">
        <div class="hero-badge">
            <span class="hero-badge-dot"></span>
            Who We Are
        </div>
        <h1>Connecting Talent with<br/><span style="background:linear-gradient(135deg, var(--accent), var(--accent-2)); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;">Opportunity</span></h1>
        <p>
            JobBoard is a premium, enterprise-ready portal designed to streamline recruitment. We empower candidates to find dream careers and enable employers to hire top talent efficiently.
        </p>
    </div>
</div>

<!-- Stats Grid -->
<div class="stats-grid reveal reveal-delay-1" style="max-width:900px; margin:0 auto 4rem;">
    <div class="stat-card">
        <span class="stat-value">12K+</span>
        <span class="stat-label">Active Jobs</span>
    </div>
    <div class="stat-card">
        <span class="stat-value">4.8K+</span>
        <span class="stat-label">Verified Companies</span>
    </div>
    <div class="stat-card">
        <span class="stat-value">95%</span>
        <span class="stat-label">Success Rate</span>
    </div>
    <div class="stat-card">
        <span class="stat-value">2M+</span>
        <span class="stat-label">Messages Exchanged</span>
    </div>
</div>

<!-- Features Section -->
<div style="max-width:900px; margin:0 auto;" class="reveal reveal-delay-2">
    <h2 style="text-align:center; font-size:1.8rem; font-weight:900; margin-bottom:2.5rem; background:linear-gradient(135deg, #fff, var(--text-secondary)); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;">
        What Makes Us Unique
    </h2>

    <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(280px, 1fr)); gap:1.5rem; margin-bottom:3rem;">
        <div class="card">
            <div style="font-size:2rem; margin-bottom:1rem;">⚡</div>
            <h3 style="font-size:1.05rem; font-weight:800; margin-bottom:0.5rem; color:var(--accent-light);">Instant Messaging</h3>
            <p style="font-size:0.875rem; color:var(--text-secondary); line-height:1.6;">
                Chat in real-time with employers using our global floating chat widget and mini-chat drawer. No page refreshes required.
            </p>
        </div>

        <div class="card">
            <div style="font-size:2rem; margin-bottom:1rem;">📄</div>
            <h3 style="font-size:1.05rem; font-weight:800; margin-bottom:0.5rem; color:var(--accent-light);">Secure CV Attachments</h3>
            <p style="font-size:0.875rem; color:var(--text-secondary); line-height:1.6;">
                Candidates can upload a PDF or DOCX resume (max 1MB) directly to their application for instant employer review.
            </p>
        </div>

        <div class="card">
            <div style="font-size:2rem; margin-bottom:1rem;">🔍</div>
            <h3 style="font-size:1.05rem; font-weight:800; margin-bottom:0.5rem; color:var(--accent-light);">Smart Filtering</h3>
            <p style="font-size:0.875rem; color:var(--text-secondary); line-height:1.6;">
                Easily filter job listings by categories, salary ranges, location, or type (Remote, Full-time, Contract).
            </p>
        </div>
    </div>

    <!-- Vision Statement Card -->
    <div class="card" style="padding:2.5rem; text-align:center; position:relative; overflow:hidden;">
        <div style="position:absolute; top:-20px; left:-20px; font-size:6rem; opacity:0.04; font-family:serif; pointer-events:none;">"</div>
        <h3 style="font-size:1.2rem; font-weight:800; margin-bottom:1rem; color:#fff;">Our Vision</h3>
        <p style="color:var(--text-secondary); font-style:italic; line-height:1.7; max-width:650px; margin:0 auto;">
            "We believe job search shouldn't be an endless black box. By integrating instant messaging and file-sharing, we foster open, transparent communication between recruiters and applicants to build cohesive teams."
        </p>
    </div>
</div>
